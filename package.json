{
  "name": "claudeparty",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "description": "Menubar app for tracking Claude instances",
  "main": ".vite/build/index.js",
  "scripts": {
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "sync-cats": "tsx scripts/sync-cat-svgs.ts",
    "lint:fix": "prettier --write 'src/**/*.{ts,vue,css}'",
    "test": "npm run test:main && npm run test:render",
    "test:render": "vitest run -r src/render --passWithNoTests",
    "test:main": "vitest run -r src/main --passWithNoTests",
    "test:e2e": "vitest run"
  },
  "dependencies": {
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/compiler-sfc": "3.5.29",
    "@vue/test-utils": "2.4.6",
    "baseline-browser-mapping": "^2.10.0",
    "electron": "40.6.1",
    "happy-dom": "20.7.0",
    "playwright": "1.58.2",
    "prettier": "^3.8.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
